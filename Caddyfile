{$APP_DOMAIN:localhost} {
	encode zstd gzip

	request_body {
		max_size 25MB
	}

	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}

	@privateDocuments path /api/documents/*/preview /api/documents/*/download
	header @privateDocuments Cache-Control "private, no-store, max-age=0"
	header @privateDocuments Pragma "no-cache"
	header @privateDocuments X-Accel-Buffering "no"

	reverse_proxy app:3000 {
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
		flush_interval -1
	}
}
