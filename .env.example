# Runtime
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Profil A - SQLite / dusuk maliyetli VPS
# SQLite yolu prisma klasorune gore yorumlanir.
DATABASE_URL="file:./dev.db"

# Profil B - Cloud / serverless production
# Not: Mevcut Prisma schema SQLite provider ile gelir. PostgreSQL icin README'deki
# Cloud/Serverless profil talimatini izleyip datasource provider ve migrationlari ayri hazirlayin.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Production'da en az 32 karakterlik rastgele bir deger kullanin.
# AUTH_SECRET tercih edilir; SESSION_SECRET geriye donuk uyumluluk icin desteklenir.
AUTH_SECRET="change-this-to-a-long-random-string-32chars"
SESSION_SECRET="change-this-to-a-long-random-string-32chars"

# Seed ile olusturulacak ilk kullanici.
ADMIN_EMAIL="avukat@example.com"
ADMIN_PASSWORD="ChangeThisPassword2026!"

# Opsiyonel SQLite backup konumu.
BACKUP_DIR="./backups"

# V3 belge merkezi private storage konumu. Public klasor kullanilmaz.
# Docker/VPS icin kalici volume mount edilmelidir.
DOCUMENT_STORAGE_DIR="./storage/documents"

# Belge yukleme limiti ayarlardan documentMaxUploadSizeMb ile degistirilebilir.
DOCUMENT_MAX_UPLOAD_SIZE_MB="20"

# Opsiyonel PDF fontlari. Turkce karakter icin production'da TTF font yolu verilebilir.
# PDF_FONT_PATH="/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"
# PDF_FONT_BOLD_PATH="/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"

# Docker/Caddy production ornegi
APP_DOMAIN="localhost"
# ACME_EMAIL="avukat@example.com"

# Docker Compose container icindeki kalici volume yollari.
# Bos birakilirsa docker-compose.yml guvenli varsayilanlari kullanir.
# DOCKER_APP_URL="https://localhost"
# DOCKER_DATABASE_URL="file:/data/production.db"
# DOCKER_DOCUMENT_STORAGE_DIR="/app/storage/documents"
# DOCKER_BACKUP_DIR="/app/backups"

# Opsiyonel docker-compose postgres profili icin.
POSTGRES_DB="buro_finans"
POSTGRES_USER="buro_finans"
POSTGRES_PASSWORD="change-this-postgres-password"
