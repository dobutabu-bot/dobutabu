# V3-RC1 Docker staging example
# Usage:
#   cp .env.staging.example .env.staging
#   set -a && . ./.env.staging && set +a
#   docker compose -f docker-compose.staging.yml up -d --build

STAGING_APP_URL="https://localhost"

# V3-RC1 Prisma schema currently uses SQLite provider.
# Staging app therefore uses a persistent SQLite volume by default.
STAGING_DATABASE_URL="file:/data/staging.db"

# PostgreSQL service is included in the staging stack for production topology checks.
# Switching the app itself to PostgreSQL requires a separate Prisma provider/migration plan.
STAGING_POSTGRES_DB="buro_finans_staging"
STAGING_POSTGRES_USER="buro_finans"
STAGING_POSTGRES_PASSWORD="change-this-staging-postgres-password"

# Use 32+ character random values in real staging.
STAGING_AUTH_SECRET="replace-with-random-staging-auth-secret-32chars"
STAGING_SESSION_SECRET="replace-with-random-staging-session-secret-32chars"

# Seed user created inside the staging container.
STAGING_ADMIN_EMAIL="avukat@example.com"
STAGING_ADMIN_PASSWORD="DemoAvukat2026!"

STAGING_DOCUMENT_MAX_UPLOAD_SIZE_MB="20"
