NODE_ENV=production
APP_ENV=production

# Railway domain generated after first deploy, for example:
# APP_URL=https://buro-finans-paneli-production.up.railway.app
APP_URL=

# Prisma provider is SQLite in this project. Use Railway persistent volume.
DATABASE_URL=file:/data/buro-finans.db

# Generate with: openssl rand -base64 48
AUTH_SECRET=
SESSION_SECRET=

# Private document storage must be on the Railway volume.
DOCUMENT_STORAGE_DIR=/data/documents
DOCUMENT_MAX_UPLOAD_SIZE_MB=20

# Railway injects PORT automatically. Do not hard-code it.
# PORT=

# Optional initial seed/setup defaults. Change before production use.
ADMIN_EMAIL=avukat@example.com
ADMIN_PASSWORD=DemoAvukat2026!

TRUST_PROXY=true
